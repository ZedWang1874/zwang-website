---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Zedong Wang">
  <div class="max-w-4xl mx-auto px-6 pt-16 pb-20">
    <h1 class="text-3xl font-semibold text-neutral-900 dark:text-neutral-100 mb-4">Contact</h1>
    <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed mb-8 max-w-2xl">
      Open to interesting projects, collaboration, and conversations. Feel free to reach out through any of the channels below.
    </p>

    <div class="space-y-4">
      <div class="flex items-center gap-3">
        <span class="text-sm font-medium text-neutral-900 dark:text-neutral-200 w-16">Email</span>
        <a href="mailto:hello@zwang.io" class="text-sm text-[var(--color-accent)] hover:underline underline-offset-4">hello@zwang.io</a>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-sm font-medium text-neutral-900 dark:text-neutral-200 w-16">GitHub</span>
        <a href="https://github.com/ZedWang1874" target="_blank" rel="noopener noreferrer" class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-[var(--color-accent)] transition-colors">github.com/ZedWang1874</a>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-sm font-medium text-neutral-900 dark:text-neutral-200 w-16">LinkedIn</span>
        <a href="https://www.linkedin.com/in/zedong-wang-760397192/" target="_blank" rel="noopener noreferrer" class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-[var(--color-accent)] transition-colors">linkedin.com/in/zedong-wang</a>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-sm font-medium text-neutral-900 dark:text-neutral-200 w-16">Based in</span>
        <span class="text-sm text-neutral-500 dark:text-neutral-400">California, US</span>
      </div>
    </div>
  </div>
</BaseLayout>