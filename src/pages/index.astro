---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';

const featuredProjects = projects.filter((p) => p.featured).slice(0, 3);
---

<BaseLayout title="Zedong Wang — Software Engineer">
  <HeroSection />

  <!-- About blurb -->
  <section class="max-w-4xl mx-auto px-6 pb-16">
    <div class="rounded-xl border border-neutral-200 dark:border-neutral-800 p-8">
      <h2 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100 mb-3">About me</h2>
      <p class="text-neutral-500 dark:text-neutral-400 leading-relaxed mb-5 max-w-2xl">
        I'm a Full-stack engineer who cares about craft — clean code, good interfaces, and software that
        actually holds up. I work mostly in React and TypeScript, and I'm increasingly interested in
        how AI fits into the products we build.
      </p>
      <a
        href="/about"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-accent)] hover:underline underline-offset-4"
      >
        More about me →
      </a>
    </div>
  </section>

  <!-- Projects -->
  <section class="max-w-4xl mx-auto px-6 pb-20">
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100">Projects</h2>
      <a href="/projects" class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-[var(--color-accent)] transition-colors">
        All projects →
      </a>
    </div>
    <div class="grid sm:grid-cols-2 gap-4">
      {featuredProjects.map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>
</BaseLayout>
