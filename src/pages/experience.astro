---
import BaseLayout from '../layouts/BaseLayout.astro';
import { experience } from '../data/experience';
---

<BaseLayout title="Experience — Zedong Wang">
  <div class="max-w-4xl mx-auto px-6 pt-16 pb-20">
    <h1 class="text-3xl font-semibold text-neutral-900 dark:text-neutral-100 mb-8">Experience</h1>

    <div class="space-y-10">
      {experience.map((job) => (
        <article class="relative pl-6 border-l-2 border-neutral-200 dark:border-neutral-800">
          <div class="absolute -left-[7px] top-1.5 w-3 h-3 rounded-full bg-neutral-300 dark:bg-neutral-700" />
          <div class="mb-3">
            <h2 class="font-semibold text-neutral-900 dark:text-neutral-100">{job.role}</h2>
            <p class="text-sm text-neutral-500 dark:text-neutral-400">
              {job.company} · {job.start} – {job.end}
            </p>
          </div>
          <ul class="space-y-2">
            {job.bullets.map((bullet) => (
              <li class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed pl-4 relative before:content-[''] before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:rounded-full before:bg-neutral-300 dark:before:bg-neutral-700">
                {bullet}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <!-- Education -->
    <div class="mt-16">
      <h2 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100 mb-6">Education</h2>
      <div class="pl-6 border-l-2 border-neutral-200 dark:border-neutral-800 relative">
        <div class="absolute -left-[7px] top-1.5 w-3 h-3 rounded-full bg-neutral-300 dark:bg-neutral-700" />
        <p class="font-semibold text-neutral-900 dark:text-neutral-100">M.S. Computer Science</p>
        <p class="text-sm text-neutral-500 dark:text-neutral-400">Syracuse University · 2019 – 2021</p>
      </div>
    </div>
  </div>
</BaseLayout>